{
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://*:5041"
      }
    }
  },

  "Logging": {
    "file": {
      "LogLevel": {
        "Default": "Information",
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "Console": {
      "IncludeScopes": true
    }
  },
  "AllowedHosts": "*",

  "Serilog": {
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "",
          "rollingInterval": "Day"
        }
      }
    ]
  },

  "AppSettings": { "InstructionsFileName": "D:\\1WorkSecurity\\ReServer\\ReServer.json" },

  "VersionInfo": {
    "AppSettingsVersion": "1.1"
  }

}